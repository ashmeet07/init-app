"""
{{ project_name }} - {{ fw_name | upper }} starter server
Generated by {{ APP_NAME }} v{{ version }}
"""

import json
import os
import sys
from pathlib import Path


PROJECT_NAME = "{{ project_name }}"
FRAMEWORK = "{{ fw_name }}"
BUILD_STRATEGY = "{{ build_strategy }}"
APP_BRAND = "{{ APP_NAME }}"
APP_VERSION = "{{ version }}"
HOST = "{{ host | default('0.0.0.0') }}"
PORT = {{ port if (port and port != 'na') else 8000 }}
UI_FOLDER = "{{ ui_folder | default('ui') }}"
BASE_DIR = Path(__file__).resolve().parent
UI_PATH = BASE_DIR / UI_FOLDER


def missing_dependency(package_name):
    print(f"\nMissing dependency: {package_name}")
    print("Install the generated project requirements first:")
    print("  python -m pip install -r requirements.txt\n")
    sys.exit(1)


def project_meta():
    return {
        "name": PROJECT_NAME,
        "framework": FRAMEWORK,
        "strategy": BUILD_STRATEGY,
        "status": "online",
        "generated_by": APP_BRAND,
        "generator_version": APP_VERSION,
    }


def index_html():
    page = UI_PATH / "index.html"
    if page.exists():
        return page.read_text(encoding="utf-8")

    return (
        "<!doctype html><html><head><title>"
        + PROJECT_NAME
        + "</title></head><body><h1>"
        + PROJECT_NAME
        + "</h1><p>Generated by "
        + APP_BRAND
        + ".</p></body></html>"
    )


{% if fw_name == 'fastapi' %}
try:
    from fastapi import FastAPI
    from fastapi.responses import HTMLResponse
    from fastapi.staticfiles import StaticFiles
except ModuleNotFoundError as exc:
    missing_dependency(exc.name)

app = FastAPI(title=PROJECT_NAME, version="0.1.0")

if (UI_PATH / "static").exists():
    app.mount("/static", StaticFiles(directory=str(UI_PATH / "static")), name="static")


@app.get("/", response_class=HTMLResponse)
async def home():
    return index_html()


@app.get("/health")
async def health():
    return {"status": "online", "framework": FRAMEWORK}


@app.get("/api/about")
async def about():
    return project_meta()


