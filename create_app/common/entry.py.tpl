{% elif fw_name == 'bottle' %}
    run(app, host=HOST, port=PORT, debug=True)
{% elif fw_name == 'tornado' %}
    make_app().listen(PORT, address=HOST)
    tornado.ioloop.IOLoop.current().start()
{% elif fw_name == 'falcon' %}
    with make_server(HOST, PORT, app) as server:
        server.serve_forever()
{% elif fw_name == 'pyramid' %}
    serve(app, host=HOST, port=PORT)
{% elif fw_name == 'django' %}
    execute_from_command_line([sys.argv[0], "runserver", f"{HOST}:{PORT}"])
{% else %}
    ThreadingHTTPServer((HOST, PORT), StarterHandler).serve_forever()
{% endif %}
